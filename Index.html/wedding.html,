```html
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Emma & James | Wedding Invitation</title>

<link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Cormorant+Garamond:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
:root{
    --sage:#8FA58A;
    --sage-dark:#5E735A;
    --sage-light:#DCE6D8;
    --cream:#F7F4ED;
    --gold:#D4AF37;
    --text:#32412F;
    --white:#ffffff;
}

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

html{
    scroll-behavior:smooth;
}

body{
    font-family:'Cormorant Garamond', serif;
    background:linear-gradient(to bottom,#f7f4ed,#eef4ec);
    color:var(--text);
    overflow-x:hidden;
}

.hero{
    min-height:100vh;
    background:
    linear-gradient(rgba(94,115,90,.75),
    rgba(94,115,90,.75)),
    url('https://images.unsplash.com/photo-1519741497674-611481863552?auto=format&fit=crop&w=1800&q=80');
    background-size:cover;
    background-position:center;
    display:flex;
    justify-content:center;
    align-items:center;
    text-align:center;
    color:white;
    padding:20px;
}

.hero-content{
    max-width:800px;
}

.hero h3{
    letter-spacing:4px;
    text-transform:uppercase;
    font-size:1rem;
}

.hero h1{
    font-family:'Great Vibes', cursive;
    font-size:7rem;
    margin:20px 0;
}

.hero p{
    font-size:1.5rem;
}

.btn{
    display:inline-block;
    margin-top:30px;
    background:white;
    color:var(--sage-dark);
    text-decoration:none;
    padding:15px 35px;
    border-radius:50px;
    font-weight:bold;
    transition:.3s;
}

.btn:hover{
    background:var(--gold);
    color:white;
}

section{
    padding:90px 20px;
}

.container{
    max-width:1100px;
    margin:auto;
}

.title{
    text-align:center;
    margin-bottom:50px;
}

.title h2{
    font-family:'Great Vibes', cursive;
    font-size:4rem;
    color:var(--sage-dark);
}

.title p{
    font-size:1.2rem;
}

.details{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:25px;
}

.card{
    background:var(--sage-light);
    border:1px solid #cfd9cb;
    border-radius:24px;
    padding:30px;
    text-align:center;
    box-shadow:0 10px 25px rgba(0,0,0,.08);
}

.card h3{
    margin-bottom:10px;
    color:var(--sage-dark);
}

.countdown{
    background:
    linear-gradient(135deg,
    var(--sage),
    var(--sage-dark));
    color:white;
    text-align:center;
}

.timer{
    display:flex;
    justify-content:center;
    flex-wrap:wrap;
    gap:20px;
    margin-top:40px;
}

.time-box{
    width:120px;
    background:white;
    color:var(--sage-dark);
    border-radius:20px;
    padding:20px;
}

.time-box span{
    display:block;
    font-size:2.2rem;
    font-weight:bold;
}

.gallery{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
    gap:20px;
}

.gallery img{
    width:100%;
    height:320px;
    object-fit:cover;
    border-radius:20px;
    box-shadow:0 8px 20px rgba(0,0,0,.08);
}

.map{
    overflow:hidden;
    border-radius:24px;
    box-shadow:0 10px 25px rgba(0,0,0,.1);
}

.rsvp-form{
    max-width:650px;
    margin:auto;
}

input,
select,
textarea{
    width:100%;
    padding:15px;
    margin-bottom:15px;
    border-radius:12px;
    border:1px solid #d9d9d9;
    font-size:1rem;
}

button{
    width:100%;
    padding:15px;
    background:var(--sage);
    color:white;
    border:none;
    border-radius:12px;
    cursor:pointer;
    font-size:1rem;
    transition:.3s;
}

button:hover{
    background:var(--sage-dark);
}

footer{
    background:var(--sage-dark);
    color:white;
    text-align:center;
    padding:50px 20px;
}

footer h2{
    font-family:'Great Vibes', cursive;
    font-size:3rem;
}

.floral{
    position:fixed;
    opacity:.08;
    font-size:180px;
    pointer-events:none;
}

.top-left{
    top:-20px;
    left:-20px;
}

.bottom-right{
    bottom:-20px;
    right:-20px;
    transform:rotate(180deg);
}

@media(max-width:768px){

.hero h1{
    font-size:4.5rem;
}

.title h2{
    font-size:3rem;
}

.hero p{
    font-size:1.2rem;
}
}
</style>
</head>
<body>

<div class="floral top-left">🌿</div>
<div class="floral bottom-right">🌿</div>

<section class="hero">
    <div class="hero-content">
        <h3>Together With Their Families</h3>
        <h1>Emma & James</h1>
        <p>Request the pleasure of your company</p>
        <p>June 20, 2027 • 3:00 PM</p>
        <a href="#details" class="btn">Open Invitation</a>
    </div>
</section>

<section id="details">
<div class="container">

<div class="title">
<h2>Wedding Details</h2>
<p>We would be honored by your presence.</p>
</div>

<div class="details">

<div class="card">
<h3>📅 Date</h3>
<p>June 20, 2027</p>
</div>

<div class="card">
<h3>⏰ Time</h3>
<p>3:00 PM</p>
</div>

<div class="card">
<h3>📍 Venue</h3>
<p>Garden Pavilion</p>
</div>

</div>

</div>
</section>

<section class="countdown">
<div class="container">

<div class="title">
<h2 style="color:white;">Countdown To Our Wedding</h2>
</div>

<div class="timer">

<div class="time-box">
<span id="days">0</span>
Days
</div>

<div class="time-box">
<span id="hours">0</span>
Hours
</div>

<div class="time-box">
<span id="minutes">0</span>
Minutes
</div>

<div class="time-box">
<span id="seconds">0</span>
Seconds
</div>

</div>

</div>
</section>

<section>
<div class="container">

<div class="title">
<h2>Our Story</h2>
<p>
Every love story is beautiful, but ours is our favorite.
Replace this text with your own story.
</p>
</div>

</div>
</section>

<section>
<div class="container">

<div class="title">
<h2>Gallery</h2>
<p>Our Favorite Moments</p>
</div>

<div class="gallery">

<img src="https://images.unsplash.com/photo-1522673607200-164d1b6ce486?w=1200" alt="">
<img src="https://images.unsplash.com/photo-1511285560929-80b456fea0bc?w=1200" alt="">
<img src="https://images.unsplash.com/photo-1519225421980-715cb0215aed?w=1200" alt="">

</div>

</div>
</section>

<section>
<div class="container">

<div class="title">
<h2>Venue Location</h2>
<p>We can't wait to celebrate with you.</p>
</div>

<div class="map">

<iframe
src="https://www.google.com/maps?q=SMX+Convention+Center+Clark&output=embed"
width="100%"
height="450"
style="border:0;"
allowfullscreen
loading="lazy">
</iframe>

</div>

</div>
</section>

<section>
<div class="container">

<div class="title">
<h2>RSVP</h2>
<p>Please let us know if you'll be attending.</p>
</div>

<form class="rsvp-form">

<input type="text" placeholder="Full Name" required>

<input type="email" placeholder="Email Address" required>

<select required>
<option value="">Select Attendance</option>
<option>Will Attend</option>
<option>Cannot Attend</option>
</select>

<textarea rows="5" placeholder="Message For The Couple"></textarea>

<button type="submit">Send RSVP</button>

</form>

</div>
</section>

<footer>
<h2>Emma & James</h2>
<p>Thank You For Celebrating With Us</p>
</footer>

<script>

const weddingDate =
new Date("June 20, 2027 15:00:00").getTime();

const timer = setInterval(() => {

const now = new Date().getTime();
const distance = weddingDate - now;

if(distance < 0){

clearInterval(timer);

document.getElementById("days").textContent = "0";
document.getElementById("hours").textContent = "0";
document.getElementById("minutes").textContent = "0";
document.getElementById("seconds").textContent = "0";

return;
}

document.getElementById("days").textContent =
Math.floor(distance / (1000 * 60 * 60 * 24));

document.getElementById("hours").textContent =
Math.floor((distance % (1000*60*60*24)) / (1000*60*60));

document.getElementById("minutes").textContent =
Math.floor((distance % (1000*60*60)) / (1000*60));

document.getElementById("seconds").textContent =
Math.floor((distance % (1000*60)) / 1000);

},1000);

document.querySelector(".rsvp-form")
.addEventListener("submit", function(e){

e.preventDefault();

alert("Thank you for your RSVP!");

this.reset();

});

</script>

</body>
</html>
